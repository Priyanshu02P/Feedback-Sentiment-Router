      "typeVersion": 1,
      "position": [
        660,
        -120
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "return [{ json: {\n  text: `:warning: BERTopic clustering job failed at ${new Date().toISOString()}. ` +\n         `Response: ${JSON.stringify($input.first().json).slice(0, 500)}`\n} }];"
      },
      "id": "c78752c6-f3e9-481d-b595-fde83bb63097",
