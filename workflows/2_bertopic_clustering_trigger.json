        "options": {
          "timeout": 600000
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "2b4c9ee7-ea59-4e1c-909a-973ed68e723b",
      "name": "Trigger BERTopic Clustering",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        0
      ],
      "notes": "Python/FastAPI service owns the embeddings -> UMAP -> HDBSCAN -> BERTopic pipeline and writes directly to feedback_clusters. n8n only kicks it off and checks the result."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.status }}",
              "rightValue": "ok",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "d92b08a5-d579-4abf-9a16-832b9d2621ab",
      "name": "Clustering Succeeded?",
